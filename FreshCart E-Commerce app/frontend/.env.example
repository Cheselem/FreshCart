# Base URL of the FastAPI backend (Phase 2 in the engineering plan)
NEXT_PUBLIC_API_URL=http://localhost:8000

# When true, the frontend reads from in-memory mock data instead of the real API.
# Useful for portfolio screenshots before backend is wired up.
NEXT_PUBLIC_USE_MOCKS=true

# Google OAuth client (used by /api/v1/auth/login OAuth2 flow)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
